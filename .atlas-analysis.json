  "keyFeatures": [
    "Modular package architecture with 12 independent packages",
    "Async utilities including retry, debounce, throttle, mutex, and queue",
    "Result monad for functional error handling",
    "Iterator utilities with combinatorics and functional operations",
    "Color manipulation with multiple color space support (RGB, HSL, LAB, OKLCH)",
    "Math utilities for 2D vectors and rectangles",
    "MDX compilation and React rendering utilities",
    "Handlebars template helpers with Zod integration",
    "HTTP request utilities including cookie parsing",
    "TypeScript-first design with full type safety",
    "Available on both npm and JSR",
    "Zero or minimal dependencies per package"
  ],
  "publicApiSurface": [
    "@temelj/async: retry, debounce, throttle, delay, mutex, queue, barrier, limit, stream",
    "@temelj/result: Result<T, E>, ok, err, isOk, isErr, map, mapErr, unwrap",
    "@temelj/iterator: range, filter, map, combinatorics, search, tree traversal",
    "@temelj/color: RGB, HSL, LAB, LCH, OKLAB, OKLCH color spaces with conversion",
    "@temelj/math: Vector2, Rectangle, math operations",
    "@temelj/string: case conversion utilities",
    "@temelj/id: ULID and UUID4 generation",
    "@temelj/value: type checking, value operations, record utilities",
    "@temelj/request: cookie parsing and manipulation",
    "@temelj/mdx: MDX compiler with plugin support",
    "@temelj/mdx-react: React components for MDX rendering",
    "@temelj/handlebars: Handlebars helpers and Zod integration"
  ]
}
